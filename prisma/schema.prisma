generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Feature Flags ───────────────────────────────────────────
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Lawyer / User Profile ───────────────────────────────────
model Lawyer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatarUrl String?
  role      String   @default("lawyer")
  firm      String?
  licenseNo String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases      Case[]
  tasks      Task[]
  activities Activity[]
  timeEntries TimeEntry[]
  comments   Comment[]
}

// ─── Team Members (Firm Staff) ────────────────────────────────
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("associate") // partner | senior_associate | associate | paralegal | trainee | admin
  phone     String?
  avatarUrl String?
  barNumber String?
  specialization String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTasks TaskAssignment[]
  comments      Comment[]
}

// ─── Clients ─────────────────────────────────────────────────
model Client {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  nationalId  String?
  address     String?
  company     String?
  type        String   @default("individual")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases Case[]
}

// ─── Cases ───────────────────────────────────────────────────
model Case {
  id               String   @id @default(cuid())
  caseNumber       String   @unique
  title            String
  description      String?
  caseType         String
  status           String   @default("intake")
  priority         String   @default("medium")
  court            String?
  jurisdiction     String?
  judge            String?
  opposingCounsel  String?
  opposingCounselFirm String?
  filedDate        DateTime?
  nextHearing      DateTime?
  statuteLimitDate DateTime?
  closedDate       DateTime?
  value            Float?
  currency         String   @default("SAR")
  notes            String?
  isPro            Boolean  @default(true)
  isVisibleToClient Boolean @default(false)
  clientAccessConfig String? // JSON: which sections client can see
  parentId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lawyerId  String
  lawyer    Lawyer  @relation(fields: [lawyerId], references: [id])
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id])
  parent    Case?   @relation("CaseHierarchy", fields: [parentId], references: [id])
  children Case[]  @relation("CaseHierarchy")

  tasks          Task[]
  documents      CaseDocument[]
  billings       Billing[]
  timelines      TimelineEvent[]
  activities     Activity[]
  parties        CaseParty[]
  comments       Comment[]
  timeEntries    TimeEntry[]
  expenses       Expense[]
  calendarEvents CalendarEvent[]
  evidenceItems  EvidenceItem[]
  privilegeLogs  PrivilegeLog[]
}

// ─── Case Parties ────────────────────────────────────────────
model CaseParty {
  id          String   @id @default(cuid())
  name        String
  role        String   // plaintiff | defendant | witness | expert | opposing_counsel | judge | third_party
  type        String   @default("individual") // individual | corporate | government
  email       String?
  phone       String?
  lawyer      String?  // representing lawyer
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Tasks ───────────────────────────────────────────────────
model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("pending")
  priority      String   @default("medium")
  dueDate       DateTime?
  completedAt   DateTime?
  category      String   @default("general") // research | drafting | filing | review | meeting | court | other
  estimatedHours Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  caseId  String
  case    Case   @relation(fields: [caseId], references: [id])
  lawyerId String
  lawyer   Lawyer @relation(fields: [lawyerId], references: [id])

  assignments TaskAssignment[]
}

// ─── Task Assignments (to team members) ──────────────────────
model TaskAssignment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  taskId     String
  task       Task   @relation(fields: [taskId], references: [id])
  memberId   String
  member     TeamMember @relation(fields: [memberId], references: [id])

  @@unique([taskId, memberId])
}

// ─── Comments / Threads ──────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  content   String
  isInternal Boolean @default(true) // true = internal only, false = visible to client
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseId   String
  case     Case   @relation(fields: [caseId], references: [id])
  lawyerId String?
  lawyer   Lawyer? @relation(fields: [lawyerId], references: [id])
  memberId String?
  member   TeamMember? @relation(fields: [memberId], references: [id])
  parentId  String?
  parent   Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentThread")
}

// ─── Case Documents ──────────────────────────────────────────
model CaseDocument {
  id           String   @id @default(cuid())
  fileName     String
  fileType     String
  fileSize     Int?
  filePath     String?
  folder       String   @default("/")
  version      Int      @default(1)
  versionOf    String?  // parent doc ID for versioning
  tags         String?  // JSON array of tags
  category     String   @default("general")
  description  String?
  isConfidential Boolean @default(false)
  isVisibleToClient Boolean @default(true)
  uploadedBy   String?
  uploadedAt   DateTime @default(now())

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Time Entries ────────────────────────────────────────────
model TimeEntry {
  id          String   @id @default(cuid())
  description String
  duration    Float    // in minutes
  rate        Float?
  isBillable  Boolean  @default(true)
  activityType String   @default("research") // research | drafting | review | meeting | court | phone | email | other
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId   String
  case     Case   @relation(fields: [caseId], references: [id])
  lawyerId String
  lawyer   Lawyer @relation(fields: [lawyerId], references: [id])
}

// ─── Expenses ────────────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  currency    String   @default("SAR")
  category    String   @default("travel") // travel | filing | expert | courier | printing | other
  isBillable  Boolean  @default(true)
 date        DateTime
  receiptPath String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Calendar Events ─────────────────────────────────────────
model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  eventType   String   @default("hearing") // hearing | filing | meeting | deadline | trial | deposition | mediation | other
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  location    String?
  color       String?
  reminder    String?  // none | 15min | 30min | 1h | 1d
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId String?
  case   Case?  @relation(fields: [caseId], references: [id])
}

// ─── Evidence Items ──────────────────────────────────────────
model EvidenceItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  itemType    String   @default("document") // document | photo | video | physical | digital | testimony
  category    String?  // email | contract | financial | communication | expert_report | other
  dateReceived DateTime?
  isPrivileged Boolean @default(false)
  privilegeType String? // attorney_client | work_product | joint_defense | other
  isConfidential Boolean @default(false)
  tags        String?  // JSON
  linkedDocId String?  // link to CaseDocument
  source      String?  // who provided it
  chainOfCustody String? // JSON array of custody entries
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Privilege Logs ──────────────────────────────────────────
model PrivilegeLog {
  id            String   @id @default(cuid())
  documentTitle String
   privilegeType String   // attorney_client | work_product | joint_defense | settlement | other
  dateCreated   DateTime?
  description   String?
  withheldFrom String?  // opposing party
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Billing ─────────────────────────────────────────────────
model Billing {
  id          String   @id @default(cuid())
  description String
  hours       Float?
  rate        Float?
  amount      Float
  currency    String   @default("SAR")
  status      String   @default("draft")
  invoiceDate DateTime?
  dueDate     DateTime?
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Timeline Events ─────────────────────────────────────────
model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  eventType   String   @default("note")
  eventDate   DateTime
  createdAt   DateTime @default(now())

  caseId String
  case   Case   @relation(fields: [caseId], references: [id])
}

// ─── Activity Log ────────────────────────────────────────────
model Activity {
  id          String   @id @default(cuid())
  action      String
  description String?
  entity      String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  lawyerId String
  lawyer   Lawyer @relation(fields: [lawyerId], references: [id])
  caseId   String?
  case     Case?   @relation(fields: [caseId], references: [id])
}